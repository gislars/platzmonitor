# Kopieren nach .env und Werte anpassen. Nur Variablen mit VITE_ stehen im Client-Build zur Verfuegung.

# --- Anzeige (Defaults fuer Panel und ohne localStorage-Override) ---

# Kachelraster: Spalten und Zeilen (1 bis 12)
# VITE_TILES_COLS=2
# VITE_TILES_ROWS=3

# Seitenwechsel Kacheln (Millisekunden, min. 5000)
# VITE_PAGE_ROTATION_MS=25000

# API-Polling (Millisekunden, min. 5000). Standard: 55000
# VITE_POLL_INTERVAL_MS=55000

# Max. Spalten fuer Gruppen nebeneinander (1 bis 6)
# VITE_MAX_GROUP_COLUMNS=2

# Seitenrotation: perGroup | global
# VITE_GROUP_ROTATION_MODE=perGroup

# Leere Gruppen ausblenden: 1/true oder 0/false
# VITE_HIDE_EMPTY_GROUPS=false

# Ausgebuchte Angebote (sold_out) ausblenden: 1/true oder 0/false
# VITE_HIDE_SOLD_OUT_ENTRIES=false

# Termine mit Startzeit in der Vergangenheit ausblenden (sortAt aus pretalx; ohne Datum bleibt sichtbar)
# VITE_HIDE_PAST_ENTRIES=false

# Theme: fossgis-light | fossgis-dark (ungueltig faellt auf fossgis-light zurueck)
# VITE_DEFAULT_THEME=fossgis-light

# Kiosk-Modus (kein Config-Panel): true | (alles andere aus)
# VITE_KIOSK=false

# --- Sonstiges ---

# Lokaler Vite-Proxy (Standard): keine Variable noetig; API unter /api/v1/availability
# Multihost oder Backend auf anderem Host:
# VITE_API_BASE_URL=https://api.example.org
# Gleicher Host mit nginx-Praefix /backend (Pfad wird korrekt an URL angehaengt):
# VITE_API_BASE_URL=https://fossgis.mapwebbing.eu/backend
