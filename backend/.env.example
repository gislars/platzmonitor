# Kopie nach backend/.env (nicht committen). Auskommentierte Zeilen sind optional.

# pretix
PRETIX_BASE_URL=https://pretix.eu
# Team-Token: Lesen von Items, Quotas und Wartelisten-Einträgen
PRETIX_TOKEN=

# Ausgehende Requests zu pretix und pretalx (leer = Standard im Code)
# HTTP_USER_AGENT=fossgis-platzmonitor/0.1.0

ORGANIZER=fossgis
EVENT=2026

# Optional: stuendlicher Workshop-Verlauf (SQLite) und Mehrtages-Aggregate (Registrierungen)
# HISTORY_DB_PATH=data/history.sqlite
# HISTORY_RETENTION_DAYS=0
# HISTORY_BUCKET_SECONDS=3600
# HISTORY_DEFAULT_WINDOW_HOURS=0
# REGISTRATIONS_DB_PATH=data/registrations.sqlite
# Kumulativer Workshop-Verlauf aus pretix transactions/ (Siehe BOOKING_TIMELINE_REFRESH_SECONDS)
# BOOKING_TIMELINE_DB_PATH=data/booking_timeline.sqlite
# BOOKING_TIMELINE_REFRESH_SECONDS=900

# Optional: pretalx-Zeitplan (Standardwerte stehen im Code)
# PRETALX_SCHEDULE_URL=https://pretalx.com/fossgis2026/schedule/export/schedule.json
# Pretalx Widget (Pausen); leer = GET /api/v1/widget-schedule liefert 404 widget_schedule_not_configured
# PRETALX_WIDGET_URL=https://pretalx.com/fossgis2026/schedule/v/latest/widgets/schedule.json
# PRETALX_SCHEDULE_CACHE_SECONDS=3600

# Optional: JSON-Datei fuer Druck-Stand (Abfahrtsmonitor-Diff); leer = 404 schedule_print_not_configured
# SCHEDULE_PRINT_PATH=/var/lib/platzmonitor/schedule-print.json

# Hintergrund-Abruf pretix/pretalx (Sekunden, min. 5). HTTP liefert nur den Zwischenspeicher.
# AVAILABILITY_REFRESH_SECONDS=55

# App-Logging (Logger pm.*). LOG_FILE leer = /var/log/platzmonitor/app.log
# LOG_LEVEL=INFO
# LOG_FILE=

# Optional: CORS in Produktion (kommagetrennte Origins)
# FRONTEND_ORIGIN=https://infoscreen.example.org
#
# Optional: CORS per Regex (Multihost); überschreibt FRONTEND_ORIGIN, wenn gesetzt
# FRONTEND_ORIGIN_REGEX=^https?://([a-z0-9-]+\.)?infoscreen\.example\.org(:\d+)?$

# Swagger UI und /openapi.json. Standard: aus (Produktion)
# DOCS_ENABLED=true
#
# ROOT_PATH: nur hinter einem URL-Prefix (z. B. deploy/nginx unter /event-api/), sonst liefert Swagger eine falsche OpenAPI-URL. Produktion: deploy/systemd setzt ROOT_PATH; lokal diese Zeile nur nötig ohne diese Unit.
# ROOT_PATH=/event-api

# Optional: Gruppen (leer = Workshops und Exkursionen wie im Code)
# Bei match.type "regex": pattern max. 256 Zeichen
# GROUP_RULES_JSON=[{"id":"workshops","title":"Workshops","match":{"type":"prefix","value":"WS"}},...]
# GROUP_UNMATCHED_BEHAVIOR=drop
# GROUP_OTHER_ID=other
# GROUP_OTHER_TITLE=Sonstiges
