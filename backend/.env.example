# Kopie nach backend/.env (nicht committen). Auskommentierte Zeilen sind optional.

# pretix
PRETIX_BASE_URL=https://pretix.eu
# Team-Token: Lesen von Items, Quotas und Wartelisten-Einträgen
PRETIX_TOKEN=

# Ausgehende Requests zu pretix und pretalx (leer = Standard im Code)
# HTTP_USER_AGENT=fossgis-platzmonitor/0.1.0

ORGANIZER=fossgis
EVENT=2026

# Optional: pretalx-Zeitplan (Standardwerte stehen im Code)
# PRETALX_SCHEDULE_URL=https://pretalx.com/fossgis2026/schedule/export/schedule.json
# PRETALX_SCHEDULE_CACHE_SECONDS=3600

# Hintergrund-Abruf pretix/pretalx (Sekunden, min. 5). HTTP liefert nur den Zwischenspeicher.
# AVAILABILITY_REFRESH_SECONDS=55

# Optional: CORS in Produktion (kommagetrennte Origins)
# FRONTEND_ORIGIN=https://infoscreen.example.org
#
# Optional: CORS per Regex (Multihost); überschreibt FRONTEND_ORIGIN, wenn gesetzt
# FRONTEND_ORIGIN_REGEX=^https?://([a-z0-9-]+\.)?infoscreen\.example\.org(:\d+)?$

# Swagger UI und /openapi.json. Standard: aus (Produktion)
# DOCS_ENABLED=true
#
# ROOT_PATH: nur hinter einem URL-Prefix (z. B. deploy/nginx unter /backend/), sonst liefert Swagger eine falsche OpenAPI-URL. Produktion: deploy/systemd setzt ROOT_PATH; lokal diese Zeile nur nötig ohne diese Unit.

# Optional: Gruppen (leer = Workshops und Exkursionen wie im Code)
# GROUP_RULES_JSON=[{"id":"workshops","title":"Workshops","match":{"type":"prefix","value":"WS"}},...]
# GROUP_UNMATCHED_BEHAVIOR=drop
# GROUP_OTHER_ID=other
# GROUP_OTHER_TITLE=Sonstiges
