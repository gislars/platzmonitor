# Kopie nach backend/.env; nicht committen.

PRETIX_BASE_URL=https://pretix.eu
# Team-Token: Lesen von Items, Quotas und (für Wartelisten-Zahlen) Waiting list entries
PRETIX_TOKEN=

# User-Agent für alle ausgehenden Requests zu pretix und pretalx (leer = Standard im Code)
# HTTP_USER_AGENT=fossgis-platzmonitor/0.1.0
ORGANIZER=fossgis
EVENT=2026

# Optional: CORS für Produktion (kommagetrennte Origins), z. B.
# FRONTEND_ORIGIN=https://infoscreen.example.org
#
# Optional: CORS Wildcard per Regex (Multihost, zB mehrere Raspberry Pi Hosts)
# Beispiel: alle Subdomains von infoscreen.example.org, optional mit Port:
# FRONTEND_ORIGIN_REGEX=^https?://([a-z0-9-]+\.)?infoscreen\.example\.org(:\d+)?$
#
# Hinweis: Wenn FRONTEND_ORIGIN_REGEX gesetzt ist, hat es Vorrang vor FRONTEND_ORIGIN.

# OpenAPI/Swagger (/docs, /openapi.json). Standard: aus. Lokal oft: DOCS_ENABLED=true
# DOCS_ENABLED=true

# Optional: Gruppen (Standard: Workshops und Exkursionen wie bisher)
# GROUP_RULES_JSON=[{"id":"workshops","title":"Workshops","match":{"type":"prefix","value":"WS"}},...]
# GROUP_UNMATCHED_BEHAVIOR=drop
# GROUP_OTHER_ID=other
# GROUP_OTHER_TITLE=Sonstiges
